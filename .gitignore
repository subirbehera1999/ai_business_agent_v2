# ==============================================================================
# .gitignore — AI Business Agent
# ==============================================================================

# ------------------------------------------------------------------------------
# Environment & Secrets — NEVER commit these
# ------------------------------------------------------------------------------
.env
.env.*
!.env.example

# ------------------------------------------------------------------------------
# Python
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
wheels/
*.whl
MANIFEST

# ------------------------------------------------------------------------------
# Virtual Environments
# ------------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.conda/
conda-env/

# ------------------------------------------------------------------------------
# Testing & Coverage
# ------------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
*.coveragerc
junit.xml
test-results/

# ------------------------------------------------------------------------------
# Type Checking
# ------------------------------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json
.pyright/

# ------------------------------------------------------------------------------
# Linting
# ------------------------------------------------------------------------------
.ruff_cache/

# ------------------------------------------------------------------------------
# Database & Migrations
# ------------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
alembic/versions/*.pyc

# ------------------------------------------------------------------------------
# Logs
# ------------------------------------------------------------------------------
*.log
logs/
log/

# ------------------------------------------------------------------------------
# IDE & Editors
# ------------------------------------------------------------------------------
.vscode/
.idea/
*.iml
*.ipr
*.iws
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ------------------------------------------------------------------------------
# Jupyter Notebooks (dev only — not part of the app)
# ------------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# ------------------------------------------------------------------------------
# OS
# ------------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ------------------------------------------------------------------------------
# Docker (if added later)
# ------------------------------------------------------------------------------
.dockerignore

# ------------------------------------------------------------------------------
# Temporary files
# ------------------------------------------------------------------------------
*.tmp
*.bak
*.orig
*.env.tmp