# ==============================================================================
# AI BUSINESS AGENT — ENVIRONMENT CONFIGURATION EXAMPLE
# ==============================================================================
# Copy this file to .env and fill in real values before running the application.
# Never commit .env to version control.
# All values here are placeholders only.
# ==============================================================================


# ------------------------------------------------------------------------------
# APPLICATION
# ------------------------------------------------------------------------------
APP_ENV=production
APP_NAME=AI Business Agent
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=your-strong-random-secret-key-minimum-32-characters
APP_DEBUG=false
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com


# ------------------------------------------------------------------------------
# DATABASE — PostgreSQL
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://db_user:db_password@db_host:5432/ai_business_agent
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_ECHO=false


# ------------------------------------------------------------------------------
# AI — OpenAI API
# ------------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=1000
OPENAI_TEMPERATURE=0.7
OPENAI_REQUEST_TIMEOUT=30
EXTERNAL_API_TIMEOUT_SECONDS=30


# ------------------------------------------------------------------------------
# PAYMENTS — Razorpay
# ------------------------------------------------------------------------------
RAZORPAY_KEY_ID=rzp_live_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_signing_secret
RAZORPAY_CURRENCY=INR


# ------------------------------------------------------------------------------
# MESSAGING — WhatsApp Cloud API (Meta)
# ------------------------------------------------------------------------------
META_WHATSAPP_ACCESS_TOKEN=your-whatsapp-cloud-api-token
META_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-whatsapp-business-account-id
WHATSAPP_API_VERSION=v19.0
WHATSAPP_API_BASE_URL=https://graph.facebook.com


# ------------------------------------------------------------------------------
# GOOGLE — Reviews & Sheets Integration
# ------------------------------------------------------------------------------
GOOGLE_API_KEY=your-google-api-key
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=https://yourdomain.com/api/v1/auth/google/callback
GOOGLE_PLACES_API_KEY=your-google-places-api-key
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=/path/to/service-account.json
GOOGLE_MY_BUSINESS_ACCESS_TOKEN=your-google-my-business-access-token-or-leave-empty-in-dev


# ------------------------------------------------------------------------------
# ADMIN
# ------------------------------------------------------------------------------
ADMIN_WHATSAPP_NUMBER=+91XXXXXXXXXX
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_SECRET_TOKEN=your-admin-secret-token-for-internal-endpoints


# ------------------------------------------------------------------------------
# SCHEDULER
# ------------------------------------------------------------------------------
# Cron expressions (24-hour UTC)
SCHEDULER_REVIEW_POLL_INTERVAL_MINUTES=15
SCHEDULER_SALES_ANALYSIS_CRON=0 7 * * *
SCHEDULER_WEEKLY_REPORT_CRON=0 8 * * 1
SCHEDULER_MONTHLY_REPORT_CRON=0 8 1 * *
SCHEDULER_QUARTERLY_REPORT_CRON=0 8 1 1,4,7,10 *
SCHEDULER_WEEKLY_CONTENT_CRON=0 9 * * 1
SCHEDULER_EXPIRY_CHECK_CRON=0 6 * * *
SCHEDULER_HEALTH_REPORT_CRON=0 8 * * *
SCHEDULER_JOB_LOCK_TTL_SECONDS=900


# ------------------------------------------------------------------------------
# USAGE LIMITS (per business per day — override per plan in plan_manager)
# ------------------------------------------------------------------------------
MAX_REVIEWS_PER_DAY=100
MAX_AI_REPLIES_PER_DAY=200
MAX_COMPETITOR_SCANS_PER_DAY=10
MAX_REPORTS_PER_DAY=5


# ------------------------------------------------------------------------------
# RETRY POLICY
# ------------------------------------------------------------------------------
RETRY_MAX_ATTEMPTS=3
RETRY_BACKOFF_DELAYS=2,5,10



# ------------------------------------------------------------------------------
# REDIS — Caching & Rate Limiting
# ------------------------------------------------------------------------------
REDIS_URL=redis://your-redis-host:6379/0


# ------------------------------------------------------------------------------
# SECURITY
# ------------------------------------------------------------------------------
JWT_SECRET_KEY=your-jwt-secret-key-minimum-32-characters
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
ENCRYPTION_KEY=your-fernet-encryption-key-base64-encoded-32-bytes


# ------------------------------------------------------------------------------
# LOGGING
# ------------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=/var/log/ai_business_agent/app.log
LOG_ROTATION=daily
LOG_RETENTION_DAYS=30
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id


# ------------------------------------------------------------------------------
# FEEDBACK
# ------------------------------------------------------------------------------
FEEDBACK_GOOGLE_FORM_URL=https://forms.gle/your-feedback-form-link
FEEDBACK_REQUEST_DELAY_DAYS=30


# ------------------------------------------------------------------------------
# RATE LIMITING
# ------------------------------------------------------------------------------
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10


# ------------------------------------------------------------------------------
# BATCH PROCESSING
# ------------------------------------------------------------------------------
BATCH_SIZE_BUSINESSES=20
BATCH_SIZE_RECORDS=50
